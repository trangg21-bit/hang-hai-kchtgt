# ============================================================
# M-001 Quan tri he thong — Environment Variables
# ============================================================
# Copy to .env and set real values before production.
# NEVER commit .env to version control.
# ============================================================

# -- JWT Signing Secret ------------------------------------------------
# Must be Base64-encoded, minimum 32 bytes (256 bits).
# Production: use a cryptographically random value, e.g.:
#   pwgen -s 48 1 | base64
JWT_SECRET=Chuyen-Doi-So-2026-QuanTriHeThong-JWT-Secret-Key-256bit

# -- AES-256 Encryption Key --------------------------------------------
# Must be a 32-byte (256-bit) value, Base64-encoded.
# Production: use `openssl rand -base64 32`
ENCRYPTION_KEY=Q3V0-Loc-2026-AES-256-Encryption-Key-B64
